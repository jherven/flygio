@rendermode InteractiveServer
@using Flygio.Configuration
@inject NavigationManager Navigation

<div class="glass rounded-2xl shadow-2xl p-6 md:p-8 max-w-3xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <!-- Från -->
        <div class="relative">
            <label for="from" class="block text-sm font-semibold text-brand mb-1.5">Från</label>
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
                <input id="from" type="text" list="airports-from" @bind="FromInput" placeholder="Stockholm (ARN)"
                       class="w-full bg-sand border border-gray-200 rounded-xl pl-10 pr-3 py-3 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all" />
            </div>
            <datalist id="airports-from">
                @foreach (var airport in IataData.SwedishAirports)
                {
                    <option value="@airport.Key">@airport.Value (@airport.Key)</option>
                }
            </datalist>
        </div>

        <!-- Swap button + Till -->
        <div class="relative">
            <label for="to" class="block text-sm font-semibold text-brand mb-1.5">Till</label>
            <!-- Swap button -->
            <button type="button" @onclick="SwapFromTo"
                    class="hidden md:flex absolute -left-6 top-1/2 translate-y-0.5 z-10 w-8 h-8 bg-white border border-gray-200 rounded-full items-center justify-center shadow-sm hover:bg-sand transition-colors"
                    title="Byt från/till">
                <svg class="w-4 h-4 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
                </svg>
            </button>
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <input id="to" type="text" list="airports-to" @bind="ToInput" placeholder="Barcelona (BCN)"
                       class="w-full bg-sand border border-gray-200 rounded-xl pl-10 pr-3 py-3 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all" />
            </div>
            <datalist id="airports-to">
                @foreach (var dest in IataData.PopularDestinations)
                {
                    <option value="@dest.Key">@dest.Value (@dest.Key)</option>
                }
                @foreach (var airport in IataData.SwedishAirports)
                {
                    <option value="@airport.Key">@airport.Value (@airport.Key)</option>
                }
            </datalist>
        </div>

        <!-- Datum -->
        <div>
            <label for="date" class="block text-sm font-semibold text-brand mb-1.5">Datum</label>
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <input id="date" type="date" @bind="DateInput" min="@DateTime.Today.ToString("yyyy-MM-dd")"
                       class="w-full bg-sand border border-gray-200 rounded-xl pl-10 pr-3 py-3 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all" />
            </div>
        </div>

        <!-- Sök-knapp -->
        <div>
            <button @onclick="DoSearch"
                    class="w-full bg-accent hover:bg-accent-hover text-white font-bold py-3 rounded-xl transition-all shadow-lg hover:shadow-xl animate-pulse-glow flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                Sök flyg
            </button>
        </div>
    </div>
</div>

@code {
    private string FromInput { get; set; } = "";
    private string ToInput { get; set; } = "";
    private DateTime? DateInput { get; set; }

    private void SwapFromTo()
    {
        (FromInput, ToInput) = (ToInput, FromInput);
    }

    private void DoSearch()
    {
        var from = ExtractIata(FromInput);
        var to = ExtractIata(ToInput);

        if (string.IsNullOrEmpty(from) || string.IsNullOrEmpty(to)) return;

        var url = $"/sok?from={from}&to={to}";
        if (DateInput.HasValue)
            url += $"&date={DateInput.Value:yyyy-MM-dd}";

        Navigation.NavigateTo(url);
    }

    private static string ExtractIata(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return "";
        var trimmed = input.Trim().ToUpperInvariant();
        if (trimmed.Length == 3) return trimmed;
        // Try to extract from "City (IATA)" format
        var parenStart = input.LastIndexOf('(');
        var parenEnd = input.LastIndexOf(')');
        if (parenStart >= 0 && parenEnd > parenStart)
        {
            return input[(parenStart + 1)..parenEnd].Trim().ToUpperInvariant();
        }
        return trimmed.Length >= 3 ? trimmed[..3] : trimmed;
    }
}
