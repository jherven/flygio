@using Flygio.Services.DTOs
@inject IJSRuntime JS

<div class="bg-white rounded-xl shadow-md p-5">
    <h3 class="text-lg font-display text-brand mb-4">@Title</h3>
    <canvas id="@_canvasId" style="max-height: 300px;"></canvas>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Prisutveckling";
    [Parameter] public List<CalendarPrice> Prices { get; set; } = [];

    private readonly string _canvasId = $"chart-{Guid.NewGuid():N}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Prices.Count > 0)
        {
            var labels = Prices.OrderBy(p => p.Date).Select(p => p.Date.ToString("d MMM", new System.Globalization.CultureInfo("sv-SE"))).ToArray();
            var data = Prices.OrderBy(p => p.Date).Select(p => p.Price).ToArray();

            await JS.InvokeVoidAsync("eval", $$"""
                (function() {
                    const ctx = document.getElementById('{{_canvasId}}');
                    if (!ctx) return;
                    const gradient = ctx.getContext('2d').createLinearGradient(0, 0, 0, 300);
                    gradient.addColorStop(0, 'rgba(30, 58, 95, 0.15)');
                    gradient.addColorStop(1, 'rgba(30, 58, 95, 0.01)');
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: {{System.Text.Json.JsonSerializer.Serialize(labels)}},
                            datasets: [{
                                label: 'Pris (SEK)',
                                data: {{System.Text.Json.JsonSerializer.Serialize(data)}},
                                borderColor: '#1e3a5f',
                                backgroundColor: gradient,
                                fill: true,
                                tension: 0.4,
                                pointRadius: 4,
                                pointHoverRadius: 7,
                                pointBackgroundColor: '#f59e0b',
                                pointBorderColor: '#1e3a5f',
                                pointBorderWidth: 2,
                                borderWidth: 2.5
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: '#1e3a5f',
                                    titleFont: { family: 'Inter' },
                                    bodyFont: { family: 'Inter', weight: 'bold' },
                                    padding: 12,
                                    cornerRadius: 8,
                                    callbacks: {
                                        label: function(ctx) { return ctx.parsed.y.toLocaleString('sv-SE') + ' SEK'; }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: false,
                                    grid: { color: 'rgba(30, 58, 95, 0.06)' },
                                    ticks: {
                                        font: { family: 'Inter', size: 11 },
                                        color: '#64748b',
                                        callback: function(v) { return v.toLocaleString('sv-SE') + ' kr'; }
                                    }
                                },
                                x: {
                                    grid: { display: false },
                                    ticks: {
                                        font: { family: 'Inter', size: 11 },
                                        color: '#64748b'
                                    }
                                }
                            }
                        }
                    });
                })();
            """);
        }
    }
}
