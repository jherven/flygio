@using Flygio.Services.DTOs
@inject IJSRuntime JS

<div class="bg-white rounded-2xl shadow-md p-6 glow-brand">
    <h3 class="font-display text-lg text-brand mb-5">@Title</h3>
    <canvas id="@_canvasId" style="max-height: 300px;"></canvas>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Prisutveckling";
    [Parameter] public List<CalendarPrice> Prices { get; set; } = [];

    private readonly string _canvasId = $"chart-{Guid.NewGuid():N}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Prices.Count > 0)
        {
            var labels = Prices.OrderBy(p => p.Date).Select(p => p.Date.ToString("d MMM", new System.Globalization.CultureInfo("sv-SE"))).ToArray();
            var data = Prices.OrderBy(p => p.Date).Select(p => p.Price).ToArray();

            await JS.InvokeVoidAsync("eval", $$"""
                (function() {
                    const ctx = document.getElementById('{{_canvasId}}');
                    if (!ctx) return;
                    const gradient = ctx.getContext('2d').createLinearGradient(0, 0, 0, 300);
                    gradient.addColorStop(0, 'rgba(30, 58, 95, 0.12)');
                    gradient.addColorStop(1, 'rgba(30, 58, 95, 0.0)');
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: {{System.Text.Json.JsonSerializer.Serialize(labels)}},
                            datasets: [{
                                label: 'Pris (SEK)',
                                data: {{System.Text.Json.JsonSerializer.Serialize(data)}},
                                borderColor: '#1e3a5f',
                                backgroundColor: gradient,
                                fill: true,
                                tension: 0.4,
                                pointRadius: 5,
                                pointHoverRadius: 8,
                                pointBackgroundColor: '#f59e0b',
                                pointBorderColor: '#ffffff',
                                pointBorderWidth: 3,
                                pointHoverBackgroundColor: '#f59e0b',
                                pointHoverBorderColor: '#1e3a5f',
                                pointHoverBorderWidth: 2,
                                borderWidth: 2.5
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: {
                                intersect: false,
                                mode: 'index'
                            },
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: '#0f2440',
                                    titleFont: { family: 'Inter', size: 12, weight: '500' },
                                    bodyFont: { family: 'DM Serif Display', size: 16 },
                                    padding: { top: 10, bottom: 10, left: 14, right: 14 },
                                    cornerRadius: 12,
                                    displayColors: false,
                                    callbacks: {
                                        label: function(ctx) { return ctx.parsed.y.toLocaleString('sv-SE') + ' SEK'; }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: false,
                                    border: { display: false },
                                    grid: { color: 'rgba(30, 58, 95, 0.04)', drawBorder: false },
                                    ticks: {
                                        font: { family: 'Inter', size: 11 },
                                        color: '#94a3b8',
                                        padding: 8,
                                        callback: function(v) { return v.toLocaleString('sv-SE') + ' kr'; }
                                    }
                                },
                                x: {
                                    border: { display: false },
                                    grid: { display: false },
                                    ticks: {
                                        font: { family: 'Inter', size: 11 },
                                        color: '#94a3b8',
                                        padding: 8
                                    }
                                }
                            }
                        }
                    });
                })();
            """);
        }
    }
}
