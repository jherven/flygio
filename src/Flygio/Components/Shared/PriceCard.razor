@using Flygio.Configuration
@using Flygio.Services
@using Flygio.Services.DTOs
@inject AffiliateService Affiliate

<div class="group bg-white rounded-2xl overflow-hidden flex flex-col card-lift glow-hover relative">
    <!-- Top accent stripe with gradient -->
    <div class="h-1 bg-gradient-to-r from-accent via-coral to-accent bg-[length:200%_100%] group-hover:animate-gradient-x"></div>

    <div class="p-5 flex flex-col gap-3 flex-1">
        <!-- Route -->
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
                <span class="text-sm text-gray-400">@IataData.GetCityName(Offer.Origin)</span>
                <div class="flex items-center gap-1 text-accent">
                    <div class="w-1.5 h-1.5 rounded-full bg-accent/40"></div>
                    <div class="w-8 h-px bg-gradient-to-r from-accent/40 to-accent"></div>
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                    <div class="w-8 h-px bg-gradient-to-r from-accent to-accent/40"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-accent/40"></div>
                </div>
                <span class="font-semibold text-brand">@IataData.GetCityName(Offer.Destination)</span>
            </div>
        </div>

        <!-- Price + Airline -->
        <div class="flex items-end justify-between">
            <div>
                <span class="font-display text-3xl text-brand group-hover:text-gradient-brand transition-all">@Offer.Price.ToString("N0")</span>
                <span class="text-xs text-gray-400 ml-1">SEK</span>
            </div>
            <div class="text-right">
                @if (!string.IsNullOrEmpty(Offer.Airline))
                {
                    <span class="text-xs bg-sand text-brand-light px-2.5 py-1 rounded-full font-medium block mb-1">@Offer.Airline</span>
                }
                <div class="text-xs text-gray-400">
                    @Offer.DepartureDate.ToString("d MMM", new System.Globalization.CultureInfo("sv-SE"))
                    @if (Offer.ReturnDate.HasValue)
                    {
                        <span> — @Offer.ReturnDate.Value.ToString("d MMM", new System.Globalization.CultureInfo("sv-SE"))</span>
                    }
                </div>
            </div>
        </div>

        <!-- Stops -->
        @if (Offer.NumberOfChanges > 0)
        {
            <span class="inline-flex items-center gap-1 text-xs text-coral font-medium bg-coral/5 px-2.5 py-1 rounded-full w-fit border border-coral/10">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
                @Offer.NumberOfChanges byte@(Offer.NumberOfChanges > 1 ? "n" : "")
            </span>
        }
        else
        {
            <span class="inline-flex items-center gap-1 text-xs text-teal font-medium bg-teal/5 px-2.5 py-1 rounded-full w-fit border border-teal/10">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Direktflyg
            </span>
        }

        <!-- CTA -->
        <a href="/go?url=@(System.Net.WebUtility.UrlEncode(AffiliateUrl))&dest=@Offer.Destination"
           rel="nofollow sponsored"
           target="_blank"
           class="mt-auto text-center bg-gradient-to-r from-accent to-amber-500 hover:from-accent-hover hover:to-amber-600 text-white font-semibold py-2.5 rounded-xl transition-all duration-300 shadow-sm shadow-accent/20 hover:shadow-md hover:shadow-accent/30">
            Se pris & boka
        </a>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public FlightOffer Offer { get; set; } = null!;

    private string AffiliateUrl => Affiliate.GenerateLink(
        Offer.Origin,
        Offer.Destination,
        Offer.DepartureDate,
        Offer.ReturnDate);
}
