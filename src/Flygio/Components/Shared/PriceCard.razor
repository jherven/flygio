@using Flygio.Configuration
@using Flygio.Services
@using Flygio.Services.DTOs
@inject AffiliateService Affiliate

<div class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all hover:-translate-y-1 overflow-hidden flex flex-col">
    <!-- Top accent stripe -->
    <div class="h-1.5 bg-gradient-to-r from-accent to-coral"></div>

    <div class="p-5 flex flex-col gap-3 flex-1">
        <!-- Route -->
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
                <span class="text-sm text-gray-500">@IataData.GetCityName(Offer.Origin)</span>
                <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
                <span class="font-semibold text-brand">@IataData.GetCityName(Offer.Destination)</span>
            </div>
            @if (!string.IsNullOrEmpty(Offer.Airline))
            {
                <span class="text-xs bg-mist text-brand-light px-2 py-1 rounded-full font-medium">@Offer.Airline</span>
            }
        </div>

        <!-- Price -->
        <div class="flex items-end justify-between">
            <div>
                <span class="text-3xl font-bold text-brand">@Offer.Price.ToString("N0")</span>
                <span class="text-sm text-gray-500 ml-1">SEK</span>
            </div>
            <div class="text-right text-sm text-gray-500">
                <div>@Offer.DepartureDate.ToString("d MMM", new System.Globalization.CultureInfo("sv-SE"))</div>
                @if (Offer.ReturnDate.HasValue)
                {
                    <div>Retur @Offer.ReturnDate.Value.ToString("d MMM", new System.Globalization.CultureInfo("sv-SE"))</div>
                }
            </div>
        </div>

        <!-- Stops -->
        @if (Offer.NumberOfChanges > 0)
        {
            <span class="inline-flex items-center gap-1 text-xs text-coral font-medium bg-red-50 px-2 py-1 rounded-full w-fit">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
                @Offer.NumberOfChanges byte@(Offer.NumberOfChanges > 1 ? "n" : "")
            </span>
        }
        else
        {
            <span class="inline-flex items-center gap-1 text-xs text-teal font-medium bg-teal-light px-2 py-1 rounded-full w-fit">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Direktflyg
            </span>
        }

        <!-- CTA -->
        <a href="/go?url=@(System.Net.WebUtility.UrlEncode(AffiliateUrl))&dest=@Offer.Destination"
           rel="nofollow sponsored"
           target="_blank"
           class="mt-auto text-center bg-accent hover:bg-accent-hover text-white font-semibold py-2.5 rounded-lg transition-all hover:shadow-md">
            Se pris & boka
        </a>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public FlightOffer Offer { get; set; } = null!;

    private string AffiliateUrl => Affiliate.GenerateLink(
        Offer.Origin,
        Offer.Destination,
        Offer.DepartureDate,
        Offer.ReturnDate);
}
