@{
    var starsCount = (int)Math.Round(Rating / 2m);
}

<div class="flex items-center gap-3">
    <div class="flex items-baseline gap-1">
        <span class="text-2xl font-bold text-brand">@Rating.ToString("0.0")</span>
        <span class="text-sm text-gray-400 font-medium">/10</span>
    </div>
    <div class="flex gap-0.5">
        @for (var i = 1; i <= 5; i++)
        {
            <svg class="w-5 h-5 @(i <= starsCount ? "text-accent" : "text-gray-200")" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
        }
    </div>
</div>

@code {
    [Parameter] public decimal Rating { get; set; }
}
