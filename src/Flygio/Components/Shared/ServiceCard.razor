@using System.Text.Json

@{
    var pros = !string.IsNullOrEmpty(Service.Pros)
        ? JsonSerializer.Deserialize<List<string>>(Service.Pros)
        : null;
    var cons = !string.IsNullOrEmpty(Service.Cons)
        ? JsonSerializer.Deserialize<List<string>>(Service.Cons)
        : null;
}

<div class="service-card relative">
    @if (Service.IsFeatured)
    {
        <span class="absolute -top-3 left-6 bg-teal text-white text-xs font-semibold px-3 py-1 rounded-full shadow-md z-10">
            Redakt&ouml;rens val
        </span>
    }

    <a href="/tjanst/@Service.Slug" class="block group">
        <div class="flex flex-col md:flex-row items-start gap-6 p-6 md:p-8">
            <!-- Left: Rank + Logo -->
            <div class="flex items-center gap-4 md:gap-5 shrink-0">
                @if (Rank > 0)
                {
                    <span class="text-3xl md:text-4xl font-bold text-brand/20 font-display w-10 text-center">@Rank</span>
                }
                @if (!string.IsNullOrEmpty(Service.LogoUrl))
                {
                    <img src="@Service.LogoUrl" alt="@Service.Name"
                         class="w-16 h-16 md:w-20 md:h-20 rounded-2xl object-contain bg-gray-50 p-2" loading="lazy" />
                }
                else
                {
                    <div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-gradient-to-br from-brand to-brand-light flex items-center justify-center text-white font-display text-2xl md:text-3xl shrink-0">
                        @Service.Name[0]
                    </div>
                }
            </div>

            <!-- Middle: Name, description, pros/cons -->
            <div class="flex-1 min-w-0">
                <h3 class="font-display text-xl md:text-2xl text-brand group-hover:text-brand-light transition-colors mb-2">
                    @Service.Name
                </h3>
                <p class="text-gray-600 text-sm md:text-base leading-relaxed mb-4">@Service.Description</p>

                <div class="flex flex-col sm:flex-row gap-4">
                    @if (pros?.Count > 0)
                    {
                        <ul class="space-y-1.5">
                            @foreach (var pro in pros.Take(3))
                            {
                                <li class="flex items-start gap-2 text-sm text-gray-700">
                                    <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                                    </svg>
                                    @pro
                                </li>
                            }
                        </ul>
                    }
                    @if (cons?.Count > 0)
                    {
                        <ul class="space-y-1.5">
                            @foreach (var con in cons.Take(2))
                            {
                                <li class="flex items-start gap-2 text-sm text-gray-500">
                                    <svg class="w-4 h-4 text-coral shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                    @con
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <!-- Right: Rating + CTA -->
            <div class="flex md:flex-col items-center md:items-end gap-4 md:gap-3 shrink-0 w-full md:w-auto pt-4 md:pt-0 border-t md:border-t-0 md:border-l border-gray-100 md:pl-6">
                <div class="text-center md:text-right">
                    <StarRating Rating="@Service.Rating" />
                </div>
                <span class="inline-flex items-center gap-1.5 bg-gradient-to-r from-accent to-amber-500 text-white font-semibold px-5 py-2.5 rounded-xl text-sm shadow-md shadow-accent/20 group-hover:shadow-lg group-hover:shadow-accent/30 transition-all whitespace-nowrap">
                    Bes&ouml;k tj&auml;nsten
                    <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </span>
            </div>
        </div>
    </a>
</div>

@code {
    [Parameter, EditorRequired] public TravelService Service { get; set; } = null!;
    [Parameter] public int Rank { get; set; }
}
