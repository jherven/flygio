@page "/Error"
@using System.Diagnostics

<PageTitle>Något gick fel - Flygio.se</PageTitle>

<div class="max-w-lg mx-auto px-4 py-16 text-center animate-fade-in">
    <div class="w-16 h-16 bg-coral/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
        <svg class="w-8 h-8 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.464 0L4.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
    </div>
    <h1 class="font-display text-2xl text-brand mb-3">Något gick fel</h1>
    <p class="text-gray-600 mb-6">Vi beklagar! Ett oväntat fel uppstod. Vi arbetar på att lösa det.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="bg-accent hover:bg-accent-hover text-white px-6 py-2.5 rounded-xl font-medium transition-all hover:shadow-md">
            Tillbaka till startsidan
        </a>
        <a href="/sok" class="bg-white hover:bg-sand text-brand px-6 py-2.5 rounded-xl font-medium border border-gray-200 transition-colors">
            Sök flyg
        </a>
    </div>

    @if (ShowRequestId)
    {
        <p class="text-xs text-gray-400 mt-8">Referens: @RequestId</p>
    }
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
