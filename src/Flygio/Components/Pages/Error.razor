@page "/Error"
@using System.Diagnostics

<PageTitle>Något gick fel - Flygio.se</PageTitle>

<div class="max-w-lg mx-auto px-4 py-16 text-center">
    <div class="text-6xl mb-4">😕</div>
    <h1 class="text-2xl font-bold text-gray-800 mb-3">Något gick fel</h1>
    <p class="text-gray-600 mb-6">Vi beklagar! Ett oväntat fel uppstod. Vi arbetar på att lösa det.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="bg-sky-500 hover:bg-sky-600 text-white px-6 py-2.5 rounded-lg font-medium transition-colors">
            Tillbaka till startsidan
        </a>
        <a href="/sok" class="bg-white hover:bg-gray-50 text-gray-700 px-6 py-2.5 rounded-lg font-medium border border-gray-300 transition-colors">
            Sök flyg
        </a>
    </div>

    @if (ShowRequestId)
    {
        <p class="text-xs text-gray-400 mt-8">Referens: @RequestId</p>
    }
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
