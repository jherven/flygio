@page "/sok"
@inject IFlightSearchService FlightSearch

<PageTitle>Sök flyg - Flygio.se</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex" />
</HeadContent>

<div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="font-display text-3xl text-brand mb-6 animate-fade-in">Sök flyg</h1>

    <div class="mb-8">
        <SearchForm />
    </div>

    @if (!string.IsNullOrEmpty(From) && !string.IsNullOrEmpty(To))
    {
        <h2 class="font-display text-xl text-brand mb-4">
            Flyg från @IataData.GetCityName(From) till @IataData.GetCityName(To)
            @if (!string.IsNullOrEmpty(Date))
            {
                <span class="text-gray-500 font-body font-normal text-base ml-2">(@Date)</span>
            }
        </h2>

        @if (_loading)
        {
            <div class="text-center py-12">
                <div class="inline-block w-8 h-8 border-4 border-sand border-t-accent rounded-full animate-spin"></div>
                <p class="text-gray-500 mt-3">Söker flygpriser...</p>
            </div>
        }
        else if (_offers.Count > 0)
        {
            <p class="text-sm text-gray-500 mb-4">@_offers.Count flyg hittade</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                @{ var offerIdx = 0; }
                @foreach (var offer in _offers)
                {
                    <div class="animate-fade-in-up animate-delay-@(offerIdx % 6 + 1)">
                        <PriceCard Offer="offer" />
                    </div>
                    offerIdx++;
                }
            </div>
        }
        else
        {
            <div class="text-center py-12 bg-white rounded-xl shadow-md animate-fade-in">
                <!-- Travel SVG illustration -->
                <svg class="w-24 h-24 text-brand/20 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    <circle cx="12" cy="12" r="10" stroke-dasharray="4 4" />
                </svg>
                <h3 class="font-display text-lg text-brand mb-2">Inga flyg hittades</h3>
                <p class="text-gray-500 mb-4">Prova att ändra datum eller destination.</p>
                <a href="/rutter" class="text-brand-light hover:text-brand font-medium transition-colors">Se populära rutter →</a>
            </div>
        }
    }
    else
    {
        <div class="text-center py-12 text-gray-500 animate-fade-in">
            <svg class="w-16 h-16 text-brand/15 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <p>Fyll i formuläret ovan för att söka flyg.</p>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "from")] public string? From { get; set; }
    [SupplyParameterFromQuery(Name = "to")] public string? To { get; set; }
    [SupplyParameterFromQuery(Name = "date")] public string? Date { get; set; }

    private List<FlightOffer> _offers = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(From) || string.IsNullOrEmpty(To))
        {
            _loading = false;
            return;
        }

        try
        {
            var latest = await FlightSearch.GetLatestPricesAsync(From, To);
            var cheapest = await FlightSearch.GetCheapestAsync(From, To);

            var seen = new HashSet<string>();
            var merged = new List<FlightOffer>();

            foreach (var offer in latest.Concat(cheapest).OrderBy(o => o.Price))
            {
                var key = $"{offer.DepartureDate:yyyyMMdd}_{offer.Price}_{offer.Airline}";
                if (seen.Add(key))
                    merged.Add(offer);
            }

            _offers = merged;
        }
        catch
        {
            _offers = [];
        }

        _loading = false;
    }
}
