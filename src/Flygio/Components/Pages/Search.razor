@page "/sok"
@inject IFlightSearchService FlightSearch

<PageTitle>Sök flyg - Flygio.se</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex" />
</HeadContent>

<div class="max-w-7xl mx-auto px-4 py-10">
    <div class="text-center mb-8 animate-fade-in">
        <h1 class="font-display text-3xl md:text-4xl text-brand">Sök flyg</h1>
    </div>

    <div class="mb-10">
        <SearchForm />
    </div>

    @if (!string.IsNullOrEmpty(From) && !string.IsNullOrEmpty(To))
    {
        <h2 class="font-display text-xl text-brand mb-5">
            Flyg från @IataData.GetCityName(From) till @IataData.GetCityName(To)
            @if (!string.IsNullOrEmpty(Date))
            {
                <span class="text-gray-400 font-body font-normal text-sm ml-2">(@Date)</span>
            }
        </h2>

        @if (_loading)
        {
            <div class="text-center py-16">
                <div class="inline-block w-10 h-10 border-4 border-sand border-t-accent rounded-full animate-spin"></div>
                <p class="text-gray-400 mt-4 text-sm">Söker flygpriser...</p>
            </div>
        }
        else if (_offers.Count > 0)
        {
            <p class="text-sm text-gray-400 mb-5">@_offers.Count flyg hittade</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                @{ var offerIdx = 0; }
                @foreach (var offer in _offers)
                {
                    <div class="animate-fade-in-up animate-delay-@(offerIdx % 8 + 1)">
                        <PriceCard Offer="offer" />
                    </div>
                    offerIdx++;
                }
            </div>
        }
        else
        {
            <div class="text-center py-16 bg-white rounded-2xl shadow-md animate-fade-in">
                <div class="w-20 h-20 mx-auto mb-5 bg-brand/5 rounded-2xl flex items-center justify-center">
                    <svg class="w-10 h-10 text-brand/20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                </div>
                <h3 class="font-display text-xl text-brand mb-2">Inga flyg hittades</h3>
                <p class="text-gray-400 mb-5">Prova att ändra datum eller destination.</p>
                <a href="/rutter" class="inline-flex items-center gap-2 text-brand-light hover:text-brand font-medium transition-colors group">
                    Se populära rutter
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            </div>
        }
    }
    else
    {
        <div class="text-center py-16 text-gray-400 animate-fade-in">
            <div class="w-16 h-16 mx-auto mb-4 bg-brand/5 rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-brand/15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </div>
            <p>Fyll i formuläret ovan för att söka flyg.</p>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "from")] public string? From { get; set; }
    [SupplyParameterFromQuery(Name = "to")] public string? To { get; set; }
    [SupplyParameterFromQuery(Name = "date")] public string? Date { get; set; }

    private List<FlightOffer> _offers = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(From) || string.IsNullOrEmpty(To))
        {
            _loading = false;
            return;
        }

        try
        {
            var latest = await FlightSearch.GetLatestPricesAsync(From, To);
            var cheapest = await FlightSearch.GetCheapestAsync(From, To);

            var seen = new HashSet<string>();
            var merged = new List<FlightOffer>();

            foreach (var offer in latest.Concat(cheapest).OrderBy(o => o.Price))
            {
                var key = $"{offer.DepartureDate:yyyyMMdd}_{offer.Price}_{offer.Airline}";
                if (seen.Add(key))
                    merged.Add(offer);
            }

            _offers = merged;
        }
        catch
        {
            _offers = [];
        }

        _loading = false;
    }
}
