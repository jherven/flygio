@page "/flyg/{RouteCode}"
@inject IFlightSearchService FlightSearch
@inject AffiliateService Affiliate

<PageTitle>Flyg @OriginCity → @DestCity - Priser & Historik | Flygio.se</PageTitle>
<HeadContent>
    <meta name="description" content="Jämför flygpriser från @OriginCity till @DestCity. Se prishistorik, bästa månad att flyga och boka billiga flygbiljetter." />
    <meta property="og:title" content="Flyg @OriginCity → @DestCity - Flygio.se" />
    <meta property="og:description" content="Jämför flygpriser från @OriginCity till @DestCity. Se prishistorik och boka billiga flygbiljetter." />
    <link rel="canonical" href="https://flygio.se/flyg/@RouteCode" />
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "BreadcrumbList",
        "itemListElement": [
            { "@@type": "ListItem", "position": 1, "name": "Hem", "item": "https://flygio.se/" },
            { "@@type": "ListItem", "position": 2, "name": "Rutter", "item": "https://flygio.se/rutter" },
            { "@@type": "ListItem", "position": 3, "name": "@OriginCity → @DestCity", "item": "https://flygio.se/flyg/@RouteCode" }
        ]
    }
    </script>
</HeadContent>

<!-- Destination Hero -->
<section class="relative h-64 md:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('@IataData.GetDestinationImage(_destination)')"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-brand/90 via-brand/40 to-transparent"></div>
    <div class="relative z-10 h-full flex flex-col justify-end max-w-7xl mx-auto px-4 pb-8">
        <!-- Breadcrumb -->
        <nav class="text-sm text-white/70 mb-3">
            <a href="/" class="hover:text-white transition-colors">Hem</a>
            <span class="mx-1">›</span>
            <a href="/rutter" class="hover:text-white transition-colors">Rutter</a>
            <span class="mx-1">›</span>
            <span class="text-white">@OriginCity → @DestCity</span>
        </nav>
        <h1 class="font-display text-3xl md:text-4xl text-white animate-fade-in-up">Flyg från @OriginCity till @DestCity</h1>
        <p class="text-white/70 mt-1">@_origin → @_destination</p>
    </div>
</section>

<div class="max-w-7xl mx-auto px-4 py-8">
    @if (_loading)
    {
        <div class="text-center py-12">
            <div class="inline-block w-8 h-8 border-4 border-sand border-t-accent rounded-full animate-spin"></div>
        </div>
    }
    else
    {
        <!-- Price Summary -->
        @if (_monthMatrix.Count > 0)
        {
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8 -mt-10 relative z-10">
                <!-- Lowest price -->
                <div class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-teal animate-fade-in-up animate-delay-1">
                    <div class="text-sm text-gray-500 mb-1">Lägsta pris</div>
                    <div class="font-display text-3xl text-teal">@_monthMatrix.Min(m => m.Price).ToString("N0") <span class="text-base font-body text-gray-500">SEK</span></div>
                </div>
                <!-- Average -->
                <div class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-brand animate-fade-in-up animate-delay-2">
                    <div class="text-sm text-gray-500 mb-1">Genomsnittspris</div>
                    <div class="font-display text-3xl text-brand">@((int)_monthMatrix.Average(m => m.Price)) <span class="text-base font-body text-gray-500">SEK</span></div>
                </div>
                <!-- Best month -->
                <div class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-accent animate-fade-in-up animate-delay-3">
                    <div class="text-sm text-gray-500 mb-1">Bästa månad</div>
                    <div class="font-display text-3xl text-accent">
                        @{
                            var best = _monthMatrix.OrderBy(m => m.Price).First();
                        }
                        @best.Date.ToString("MMMM", new System.Globalization.CultureInfo("sv-SE"))
                    </div>
                </div>
            </div>
        }

        <!-- Price Graph -->
        @if (_monthMatrix.Count > 0)
        {
            <div class="mb-8">
                <PriceGraph Title="Prisutveckling per månad" Prices="_monthMatrix" />
            </div>
        }

        <!-- Month Matrix -->
        @if (_monthMatrix.Count > 0)
        {
            <div class="bg-white rounded-xl shadow-md p-6 mb-8">
                <h2 class="font-display text-lg text-brand mb-4">Billigaste pris per månad</h2>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
                    @foreach (var month in _monthMatrix.OrderBy(m => m.Date))
                    {
                        var isLowest = month.Price == _monthMatrix.Min(m => m.Price);
                        <div class="text-center p-3 rounded-xl transition-all @(isLowest ? "bg-teal-light border-2 border-teal shadow-sm" : "bg-sand hover:shadow-sm")">
                            <div class="text-sm text-gray-600 capitalize">@month.Date.ToString("MMM yyyy", new System.Globalization.CultureInfo("sv-SE"))</div>
                            <div class="font-display text-lg @(isLowest ? "text-teal" : "text-brand")">@month.Price.ToString("N0")</div>
                            <div class="text-xs text-gray-400">SEK</div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- CTA -->
        <div class="text-center py-8">
            <AffiliateButton Url="@_affiliateUrl" Text="@($"Sök flyg till {DestCity}")" DestinationIata="@_destination" />
            <p class="text-xs text-gray-400 mt-3">Du skickas vidare till vår partner för bokning</p>
        </div>
    }
</div>

@code {
    [Parameter] public string RouteCode { get; set; } = "";

    private string _origin = "";
    private string _destination = "";
    private string OriginCity => IataData.GetCityName(_origin);
    private string DestCity => IataData.GetCityName(_destination);

    private List<CalendarPrice> _monthMatrix = [];
    private string _affiliateUrl = "#";
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var parts = RouteCode?.Split('-');
        if (parts is not { Length: 2 })
        {
            _loading = false;
            return;
        }

        _origin = parts[0].ToUpperInvariant();
        _destination = parts[1].ToUpperInvariant();
        _affiliateUrl = Affiliate.GenerateGenericLink(_origin, _destination);

        try
        {
            _monthMatrix = await FlightSearch.GetMonthMatrixAsync(_origin, _destination);
        }
        catch
        {
            _monthMatrix = [];
        }

        _loading = false;
    }
}
