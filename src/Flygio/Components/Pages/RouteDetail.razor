@page "/flyg/{RouteCode}"
@inject IFlightSearchService FlightSearch
@inject AffiliateService Affiliate

<PageTitle>Flyg @OriginCity → @DestCity - Priser & Historik | Flygio.se</PageTitle>
<HeadContent>
    <meta name="description" content="Jämför flygpriser från @OriginCity till @DestCity. Se prishistorik, bästa månad att flyga och boka billiga flygbiljetter." />
    <meta property="og:title" content="Flyg @OriginCity → @DestCity - Flygio.se" />
    <meta property="og:description" content="Jämför flygpriser från @OriginCity till @DestCity. Se prishistorik och boka billiga flygbiljetter." />
    <link rel="canonical" href="https://flygio.se/flyg/@RouteCode" />
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "BreadcrumbList",
        "itemListElement": [
            { "@@type": "ListItem", "position": 1, "name": "Hem", "item": "https://flygio.se/" },
            { "@@type": "ListItem", "position": 2, "name": "Rutter", "item": "https://flygio.se/rutter" },
            { "@@type": "ListItem", "position": 3, "name": "@OriginCity → @DestCity", "item": "https://flygio.se/flyg/@RouteCode" }
        ]
    }
    </script>
</HeadContent>

<!-- Destination Hero with noise -->
<section class="relative h-72 md:h-96 overflow-hidden noise">
    <div class="absolute inset-0 bg-cover bg-center scale-105" style="background-image: url('@IataData.GetDestinationImage(_destination)')"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-navy-deep/95 via-brand/50 to-brand/20"></div>
    <div class="relative z-10 h-full flex flex-col justify-end max-w-7xl mx-auto px-4 pb-10">
        <nav class="text-sm text-white/50 mb-3">
            <a href="/" class="hover:text-white/80 transition-colors">Hem</a>
            <span class="mx-1.5">›</span>
            <a href="/rutter" class="hover:text-white/80 transition-colors">Rutter</a>
            <span class="mx-1.5">›</span>
            <span class="text-white/80">@OriginCity → @DestCity</span>
        </nav>
        <h1 class="font-display text-4xl md:text-5xl text-white animate-fade-in-up drop-shadow-lg">Flyg från @OriginCity till @DestCity</h1>
        <p class="text-white/50 mt-2 flex items-center gap-2">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            @_origin → @_destination
        </p>
    </div>
</section>

<!-- Wave divider -->
<div class="wave-divider bg-sand">
    <svg viewBox="0 0 1440 48" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 48L1440 48L1440 16C1320 32 1200 40 1080 32C960 24 840 0 720 0C600 0 480 24 360 32C240 40 120 32 0 16L0 48Z" fill="#0f2440"/>
    </svg>
</div>

<div class="max-w-7xl mx-auto px-4 py-8">
    @if (_loading)
    {
        <div class="text-center py-12">
            <div class="inline-block w-10 h-10 border-4 border-sand border-t-accent rounded-full animate-spin"></div>
        </div>
    }
    else
    {
        <!-- Price Summary Cards -->
        @if (_monthMatrix.Count > 0)
        {
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10 -mt-14 relative z-10">
                <div class="bg-white rounded-2xl shadow-xl p-6 text-center glow-teal animate-scale-in animate-delay-1 border border-teal/10">
                    <div class="w-10 h-10 bg-teal/10 rounded-xl flex items-center justify-center mx-auto mb-3">
                        <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"/></svg>
                    </div>
                    <div class="text-xs text-gray-400 uppercase tracking-wider mb-1">Lägsta pris</div>
                    <div class="font-display text-3xl text-teal">@_monthMatrix.Min(m => m.Price).ToString("N0") <span class="text-sm font-body text-gray-400">SEK</span></div>
                </div>
                <div class="bg-white rounded-2xl shadow-xl p-6 text-center glow-brand animate-scale-in animate-delay-2 border border-brand/10">
                    <div class="w-10 h-10 bg-brand/10 rounded-xl flex items-center justify-center mx-auto mb-3">
                        <svg class="w-5 h-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    </div>
                    <div class="text-xs text-gray-400 uppercase tracking-wider mb-1">Genomsnittspris</div>
                    <div class="font-display text-3xl text-brand">@((int)_monthMatrix.Average(m => m.Price)) <span class="text-sm font-body text-gray-400">SEK</span></div>
                </div>
                <div class="bg-white rounded-2xl shadow-xl p-6 text-center glow-hover animate-scale-in animate-delay-3 border border-accent/10">
                    <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center mx-auto mb-3">
                        <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    </div>
                    <div class="text-xs text-gray-400 uppercase tracking-wider mb-1">Bästa månad</div>
                    <div class="font-display text-3xl text-accent">
                        @{
                            var best = _monthMatrix.OrderBy(m => m.Price).First();
                        }
                        @best.Date.ToString("MMMM", new System.Globalization.CultureInfo("sv-SE"))
                    </div>
                </div>
            </div>
        }

        <!-- Price Graph -->
        @if (_monthMatrix.Count > 0)
        {
            <div class="mb-10 animate-fade-in-up animate-delay-4">
                <PriceGraph Title="Prisutveckling per månad" Prices="_monthMatrix" />
            </div>
        }

        <!-- Month Matrix -->
        @if (_monthMatrix.Count > 0)
        {
            <div class="bg-white rounded-2xl shadow-md p-6 mb-10 animate-fade-in-up animate-delay-5">
                <h2 class="font-display text-xl text-brand mb-5">Billigaste pris per månad</h2>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
                    @foreach (var month in _monthMatrix.OrderBy(m => m.Date))
                    {
                        var isLowest = month.Price == _monthMatrix.Min(m => m.Price);
                        <div class="text-center p-4 rounded-xl transition-all duration-300 cursor-default @(isLowest ? "bg-teal/5 border-2 border-teal/20 shadow-sm glow-teal" : "bg-sand/80 hover:bg-white hover:shadow-md border border-transparent")">
                            <div class="text-xs text-gray-400 capitalize font-medium">@month.Date.ToString("MMM yyyy", new System.Globalization.CultureInfo("sv-SE"))</div>
                            <div class="font-display text-xl mt-1 @(isLowest ? "text-teal" : "text-brand")">@month.Price.ToString("N0")</div>
                            <div class="text-xs text-gray-300 mt-0.5">SEK</div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- CTA -->
        <div class="text-center py-10">
            <AffiliateButton Url="@_affiliateUrl" Text="@($"Sök flyg till {DestCity}")" DestinationIata="@_destination" />
            <p class="text-xs text-gray-400 mt-4">Du skickas vidare till vår partner för bokning</p>
        </div>
    }
</div>

@code {
    [Parameter] public string RouteCode { get; set; } = "";

    private string _origin = "";
    private string _destination = "";
    private string OriginCity => IataData.GetCityName(_origin);
    private string DestCity => IataData.GetCityName(_destination);

    private List<CalendarPrice> _monthMatrix = [];
    private string _affiliateUrl = "#";
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var parts = RouteCode?.Split('-');
        if (parts is not { Length: 2 })
        {
            _loading = false;
            return;
        }

        _origin = parts[0].ToUpperInvariant();
        _destination = parts[1].ToUpperInvariant();
        _affiliateUrl = Affiliate.GenerateGenericLink(_origin, _destination);

        try
        {
            _monthMatrix = await FlightSearch.GetMonthMatrixAsync(_origin, _destination);
        }
        catch
        {
            _monthMatrix = [];
        }

        _loading = false;
    }
}
