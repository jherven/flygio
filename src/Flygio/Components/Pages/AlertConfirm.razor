@page "/bevakning/bekrafta/{Token}"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<FlygioDbContext> DbFactory

<PageTitle>Bekräfta bevakning - Flygio.se</PageTitle>

<div class="max-w-lg mx-auto px-4 py-16 text-center">
    @if (_confirmed)
    {
        <svg class="w-16 h-16 text-green-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h1 class="text-2xl font-bold text-green-800 mb-2">Bevakning aktiverad!</h1>
        <p class="text-gray-600 mb-6">Du kommer att få notiser när priset ändras på din bevakade rutt.</p>
        <a href="/" class="text-sky-600 hover:text-sky-700 font-medium">Tillbaka till startsidan →</a>
    }
    else
    {
        <svg class="w-16 h-16 text-red-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.464 0L4.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
        <h1 class="text-2xl font-bold text-gray-800 mb-2">Ogiltig länk</h1>
        <p class="text-gray-600">Denna bekräftelselänk är ogiltig eller har redan använts.</p>
    }
</div>

@code {
    [Parameter] public string Token { get; set; } = "";
    private bool _confirmed;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var alert = await db.PriceAlerts.FirstOrDefaultAsync(a => a.ConfirmationToken == Token);

            if (alert is not null && !alert.IsConfirmed)
            {
                alert.IsConfirmed = true;
                await db.SaveChangesAsync();
                _confirmed = true;
            }
        }
        catch { }
    }
}
