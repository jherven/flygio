@page "/"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<FlygioDbContext> DbFactory

<PageTitle>Flygio.se — Jämför resetjänster | Hitta bästa flyg, hotell & hyrbil</PageTitle>
<HeadContent>
    <meta name="description" content="Flygio.se — Sveriges oberoende jämförelsesajt för resetjänster. Jämför flygsökmotorer, hotellsajter, hyrbilstjänster och mer." />
    <meta property="og:title" content="Flygio.se — Jämför resetjänster" />
    <meta property="og:description" content="Sveriges oberoende jämförelsesajt för resetjänster. Hitta de bästa tjänsterna för flyg, hotell, hyrbil och mer." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://flygio.se" />
    <link rel="canonical" href="https://flygio.se/" />
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "WebSite",
        "name": "Flygio.se",
        "url": "https://flygio.se",
        "description": "Sveriges oberoende jämförelsesajt för resetjänster"
    }
    </script>
</HeadContent>

<!-- Hero -->
<section class="relative min-h-[460px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-deep via-brand to-brand-light"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(245,158,11,0.15),transparent_50%)]"></div>
    <div class="relative z-10 max-w-5xl mx-auto text-center px-4 py-20 md:py-28">
        <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-4 animate-fade-in">Sveriges oberoende jämförelsesajt</p>
        <h1 class="font-display text-5xl md:text-7xl text-white mb-6 animate-fade-in-up leading-tight">
            Hitta de bästa<br/><span class="text-gradient animate-shimmer">resetjänsterna</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 mb-10 max-w-2xl mx-auto animate-fade-in-up animate-delay-1">
            Vi jämför och recenserar flygssökmotorer, hotellsajter, hyrbilstjänster och mer — så att du kan boka smartare.
        </p>
        <div class="flex flex-wrap gap-3 justify-center animate-fade-in-up animate-delay-2">
            <a href="/kategori/flyg" class="bg-gradient-to-r from-accent to-amber-500 hover:from-accent-hover hover:to-amber-600 text-white font-semibold px-6 py-3 rounded-xl transition-all duration-300 shadow-lg shadow-accent/20 hover:shadow-xl hover:-translate-y-0.5">
                Jämför flygtjänster
            </a>
            <a href="/kategori/hotell" class="bg-white/10 hover:bg-white/20 text-white font-medium px-6 py-3 rounded-xl transition-all duration-300 backdrop-blur-sm border border-white/20">
                Jämför hotellsajter
            </a>
        </div>
    </div>
</section>

<!-- Categories Grid -->
<section class="py-16 px-4">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-10">
            <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-2 animate-fade-in">Kategorier</p>
            <h2 class="font-display text-3xl md:text-4xl text-brand animate-fade-in">Utforska resetjänster</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
            @{ var catIdx = 0; }
            @foreach (var cat in _categories)
            {
                <div class="animate-fade-in-up animate-delay-@(catIdx % 6 + 1)">
                    <CategoryCard Category="cat.Category" ServiceCount="cat.Count" />
                </div>
                catIdx++;
            }
        </div>
    </div>
</section>

<!-- Featured Services -->
@if (_featuredServices.Count > 0)
{
    <section class="py-16 px-4 bg-mist/30">
        <div class="max-w-4xl mx-auto">
            <div class="text-center mb-10">
                <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-2">Topplaceringar</p>
                <h2 class="font-display text-3xl md:text-4xl text-brand">Populära resetjänster</h2>
            </div>
            <div class="flex flex-col gap-6">
                @for (var i = 0; i < _featuredServices.Count; i++)
                {
                    <div class="animate-fade-in-up animate-delay-@(i % 6 + 1)">
                        <ServiceCard Service="_featuredServices[i]" Rank="i + 1" />
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- How it works -->
<section class="relative py-20 px-4 bg-navy-deep overflow-hidden">
    <div class="relative z-10 max-w-5xl mx-auto">
        <div class="text-center mb-14">
            <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-2 animate-fade-in">Enkelt & oberoende</p>
            <h2 class="font-display text-3xl md:text-4xl text-white animate-fade-in">Så funkar det</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="text-center animate-fade-in-up animate-delay-1">
                <div class="w-16 h-16 mx-auto mb-5 bg-gradient-to-br from-accent to-coral rounded-2xl flex items-center justify-center shadow-lg shadow-accent/20">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                <h3 class="font-display text-xl text-white mb-3">Utforska</h3>
                <p class="text-white/50 leading-relaxed">Bläddra bland kategorier och hitta rätt typ av resetjänst för dina behov.</p>
            </div>
            <div class="text-center animate-fade-in-up animate-delay-2">
                <div class="w-16 h-16 mx-auto mb-5 bg-gradient-to-br from-brand-light to-teal rounded-2xl flex items-center justify-center shadow-lg shadow-teal/20">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                </div>
                <h3 class="font-display text-xl text-white mb-3">Jämför</h3>
                <p class="text-white/50 leading-relaxed">Läs recensioner, jämför för- och nackdelar och se betyg från oss.</p>
            </div>
            <div class="text-center animate-fade-in-up animate-delay-3">
                <div class="w-16 h-16 mx-auto mb-5 bg-gradient-to-br from-teal to-accent rounded-2xl flex items-center justify-center shadow-lg shadow-accent/20">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                </div>
                <h3 class="font-display text-xl text-white mb-3">Boka</h3>
                <p class="text-white/50 leading-relaxed">Gå direkt till den tjänst som passar dig bäst och boka din resa.</p>
            </div>
        </div>
    </div>
</section>

<!-- Latest Articles -->
@if (_articles.Count > 0)
{
    <section class="py-16 px-4">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-10">
                <p class="text-accent font-semibold text-sm tracking-widest uppercase mb-2">Inspiration</p>
                <h2 class="font-display text-3xl md:text-4xl text-brand">Reseguider</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                @{ var accentColors = new[] { "from-accent to-coral", "from-coral to-brand-light", "from-teal to-brand" }; var artIdx = 0; }
                @foreach (var article in _articles.Take(3))
                {
                    var gradientClass = accentColors[artIdx % 3];
                    <a href="/guider/@article.Slug"
                       class="group bg-white rounded-2xl shadow-md overflow-hidden block card-lift animate-fade-in-up animate-delay-@(artIdx + 1)">
                        <div class="h-3 bg-gradient-to-r @gradientClass"></div>
                        <div class="p-6">
                            <h3 class="font-display text-lg text-brand mb-2 group-hover:text-brand-light transition-colors">@article.Title</h3>
                            <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed">@article.MetaDescription</p>
                        </div>
                    </a>
                    artIdx++;
                }
            </div>
            <div class="text-center mt-10">
                <a href="/guider" class="inline-flex items-center gap-2 text-brand-light hover:text-brand font-medium transition-colors group">
                    Visa alla guider
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                </a>
            </div>
        </div>
    </section>
}

@code {
    private List<(Category Category, int Count)> _categories = [];
    private List<TravelService> _featuredServices = [];
    private List<Article> _articles = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            _categories = await db.Categories
                .OrderBy(c => c.SortOrder)
                .Select(c => new { Category = c, Count = c.TravelServiceCategories.Count(tsc => tsc.TravelService.IsPublished) })
                .AsNoTracking()
                .ToListAsync()
                .ContinueWith(t => t.Result.Select(x => (x.Category, x.Count)).ToList());

            _featuredServices = await db.TravelServices
                .Where(s => s.IsPublished && s.IsFeatured)
                .OrderByDescending(s => s.Rating)
                .Take(4)
                .AsNoTracking()
                .ToListAsync();

            _articles = await db.Articles
                .Where(a => a.IsPublished)
                .OrderByDescending(a => a.CreatedAt)
                .Take(3)
                .AsNoTracking()
                .ToListAsync();
        }
        catch { }
    }
}
