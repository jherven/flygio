@page "/rutter"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<FlygioDbContext> DbFactory

<PageTitle>Populära flygrutter från Sverige | Flygio.se</PageTitle>
<HeadContent>
    <meta name="description" content="Se populära flygrutter från Stockholm, Göteborg och Malmö. Jämför priser och hitta billiga flygbiljetter till populära resmål." />
    <meta property="og:title" content="Populära flygrutter från Sverige | Flygio.se" />
    <meta property="og:description" content="Se populära flygrutter från Stockholm, Göteborg och Malmö." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://flygio.se/rutter" />
    <link rel="canonical" href="https://flygio.se/rutter" />
</HeadContent>

<div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-10 animate-fade-in">
        <h1 class="font-display text-3xl md:text-4xl text-brand mb-2">Populära flygrutter</h1>
        <p class="text-gray-600">Utforska de mest populära flygrutterna från Sverige.</p>
    </div>

    @if (_routesByOrigin.Count == 0)
    {
        <div class="text-center py-12 text-gray-500">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
            <p>Inga rutter tillgängliga ännu. Kom tillbaka snart!</p>
        </div>
    }
    else
    {
        @foreach (var group in _routesByOrigin)
        {
            <div class="mb-12">
                <h2 class="font-display text-xl text-brand mb-5 flex items-center gap-2">
                    <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                    Från @IataData.GetCityName(group.Key) <span class="text-brand-light font-body text-base font-normal">(@group.Key)</span>
                </h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
                    @foreach (var route in group.Value)
                    {
                        var img = IataData.GetDestinationImage(route.DestinationIata);
                        <a href="/flyg/@(route.OriginIata)-@(route.DestinationIata)"
                           class="group relative rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all hover:-translate-y-1 block h-48">
                            <img src="@img" alt="@route.DestinationCity" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
                            @if (route.LatestPrice > 0)
                            {
                                <div class="absolute top-3 right-3 bg-accent text-white text-sm font-bold px-3 py-1 rounded-full shadow-md">
                                    @route.LatestPrice.ToString("N0") SEK
                                </div>
                            }
                            <div class="absolute bottom-0 left-0 right-0 p-4">
                                <span class="font-display text-xl text-white">@route.DestinationCity</span>
                                <div class="text-white/70 text-xs mt-0.5">@route.OriginIata → @route.DestinationIata</div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private Dictionary<string, List<RouteWithPrice>> _routesByOrigin = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var routes = await db.FlightRoutes
                .Where(r => r.IsPopular)
                .OrderBy(r => r.OriginIata)
                .ThenBy(r => r.DestinationCity)
                .Select(r => new RouteWithPrice
                {
                    OriginIata = r.OriginIata,
                    DestinationIata = r.DestinationIata,
                    DestinationCity = r.DestinationCity,
                    LatestPrice = r.PricePoints
                        .OrderByDescending(p => p.FoundAt)
                        .Select(p => p.Price)
                        .FirstOrDefault()
                })
                .ToListAsync();

            _routesByOrigin = routes
                .GroupBy(r => r.OriginIata)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        catch
        {
            _routesByOrigin = [];
        }
    }

    private class RouteWithPrice
    {
        public string OriginIata { get; set; } = "";
        public string DestinationIata { get; set; } = "";
        public string DestinationCity { get; set; } = "";
        public int LatestPrice { get; set; }
    }
}
