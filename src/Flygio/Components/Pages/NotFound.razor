@page "/not-found"
@layout MainLayout

<PageTitle>Sidan hittades inte - Flygio.se</PageTitle>

<div class="max-w-lg mx-auto px-4 py-16 text-center animate-fade-in">
    <div class="font-display text-8xl text-brand/10 mb-4">404</div>
    <h1 class="font-display text-2xl text-brand mb-3">Sidan hittades inte</h1>
    <p class="text-gray-600 mb-6">Sidan du letar efter finns inte eller har flyttats.</p>

    <div class="bg-white rounded-xl shadow-md p-6 mb-6 text-left animate-fade-in-up animate-delay-1">
        <h2 class="font-display text-brand mb-3">Kanske du letar efter:</h2>
        <ul class="space-y-2">
            <li><a href="/sok" class="text-brand-light hover:text-brand transition-colors">Sök flyg →</a></li>
            <li><a href="/rutter" class="text-brand-light hover:text-brand transition-colors">Populära rutter →</a></li>
            <li><a href="/guider" class="text-brand-light hover:text-brand transition-colors">Reseguider →</a></li>
            <li><a href="/bevakning" class="text-brand-light hover:text-brand transition-colors">Prisbevakning →</a></li>
        </ul>
    </div>

    <a href="/" class="bg-accent hover:bg-accent-hover text-white px-6 py-2.5 rounded-xl font-medium transition-all hover:shadow-md inline-block">
        Tillbaka till startsidan
    </a>
</div>
