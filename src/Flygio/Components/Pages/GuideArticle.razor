@page "/guider/{Slug}"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<FlygioDbContext> DbFactory
@inject AffiliateService Affiliate

<div class="max-w-4xl mx-auto px-4 py-8">
    @if (_article is not null)
    {
        <PageTitle>@_article.Title | Flygio.se</PageTitle>
        <HeadContent>
            <meta name="description" content="@_article.MetaDescription" />
            <meta property="og:title" content="@_article.Title" />
            <meta property="og:description" content="@_article.MetaDescription" />
            <meta property="og:type" content="article" />
            <meta property="og:url" content="https://flygio.se/guider/@_article.Slug" />
            <link rel="canonical" href="https://flygio.se/guider/@_article.Slug" />
            <script type="application/ld+json">
            {
                "@@context": "https://schema.org",
                "@@type": "Article",
                "headline": "@_article.Title",
                "description": "@_article.MetaDescription",
                "datePublished": "@_article.CreatedAt.ToString("yyyy-MM-dd")",
                "dateModified": "@_article.UpdatedAt.ToString("yyyy-MM-dd")",
                "publisher": {
                    "@@type": "Organization",
                    "name": "Flygio.se",
                    "url": "https://flygio.se"
                }
            }
            </script>
        </HeadContent>

        <!-- Article Hero -->
        @if (!string.IsNullOrEmpty(_heroImg))
        {
            <div class="relative -mx-4 md:mx-0 mb-8 rounded-none md:rounded-2xl overflow-hidden h-64 md:h-80 animate-fade-in">
                <img src="@_heroImg" alt="@_article.Title" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-brand/80 via-brand/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6">
                    <!-- Breadcrumb -->
                    <nav class="text-sm text-white/70 mb-2">
                        <a href="/" class="hover:text-white transition-colors">Hem</a>
                        <span class="mx-1">›</span>
                        <a href="/guider" class="hover:text-white transition-colors">Guider</a>
                    </nav>
                    <h1 class="font-display text-2xl md:text-4xl text-white">@_article.Title</h1>
                    <p class="text-white/60 text-sm mt-2">Uppdaterad @_article.UpdatedAt.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("sv-SE"))</p>
                </div>
            </div>
        }
        else
        {
            <!-- Breadcrumb (no hero image) -->
            <nav class="text-sm text-gray-500 mb-6">
                <a href="/" class="hover:text-brand-light transition-colors">Hem</a>
                <span class="mx-1">›</span>
                <a href="/guider" class="hover:text-brand-light transition-colors">Guider</a>
                <span class="mx-1">›</span>
                <span class="text-gray-700">@_article.Title</span>
            </nav>
            <h1 class="font-display text-3xl md:text-4xl text-brand mb-4 animate-fade-in-up">@_article.Title</h1>
            <p class="text-gray-500 text-sm mb-8">Uppdaterad @_article.UpdatedAt.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("sv-SE"))</p>
        }

        <article class="animate-fade-in-up animate-delay-1">
            <div class="prose prose-lg max-w-none mb-8">
                @((MarkupString)_article.Content)
            </div>
        </article>

        <!-- Related route CTA -->
        @if (!string.IsNullOrEmpty(_article.DestinationIata))
        {
            <div class="bg-gradient-to-r from-brand to-brand-light rounded-xl p-6 text-center mt-8 animate-fade-in-up animate-delay-2">
                <h2 class="font-display text-xl text-white mb-3">Flyg till @_article.DestinationCity</h2>
                <p class="text-white/70 mb-4">Hitta billiga flygbiljetter till @_article.DestinationCity från Sverige.</p>
                <div class="flex flex-wrap gap-3 justify-center">
                    <a href="/flyg/ARN-@_article.DestinationIata" class="bg-white hover:bg-sand text-brand px-5 py-2.5 rounded-lg font-medium transition-colors">
                        Från Stockholm
                    </a>
                    <AffiliateButton Url="@_affiliateUrl" Text="@($"Boka flyg till {_article.DestinationCity}")" DestinationIata="@_article.DestinationIata" />
                </div>
            </div>
        }
    }
    else
    {
        <PageTitle>Artikel hittades inte | Flygio.se</PageTitle>
        <div class="text-center py-16 animate-fade-in">
            <h1 class="font-display text-2xl text-brand mb-2">Artikel hittades inte</h1>
            <p class="text-gray-500 mb-4">Denna guide finns inte eller har tagits bort.</p>
            <a href="/guider" class="text-brand-light hover:text-brand font-medium transition-colors">Visa alla guider →</a>
        </div>
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private Article? _article;
    private string _affiliateUrl = "#";
    private string _heroImg = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _article = await db.Articles.FirstOrDefaultAsync(a => a.Slug == Slug && a.IsPublished);

            if (_article?.DestinationIata is not null)
            {
                _heroImg = IataData.GetDestinationImage(_article.DestinationIata);
                _affiliateUrl = Affiliate.GenerateGenericLink("ARN", _article.DestinationIata);
            }
        }
        catch { }
    }
}
