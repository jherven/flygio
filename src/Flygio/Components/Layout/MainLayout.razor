@inherits LayoutComponentBase

<div class="min-h-screen flex flex-col bg-sand">
    <!-- Sticky Header with glass blur -->
    <header class="sticky top-0 z-50 bg-brand/95 backdrop-blur-md shadow-lg shadow-brand/10">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <a href="/" class="flex items-center gap-2.5 text-xl font-display text-white hover:text-gray-200 transition-colors group">
                    <svg class="w-7 h-7 text-accent group-hover:rotate-12 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                    flygio<span class="text-accent">.se</span>
                </a>

                <!-- Desktop Nav -->
                <div class="hidden md:flex items-center gap-1">
                    <a href="/" class="text-white/70 hover:text-white px-3 py-2 rounded-lg hover:bg-white/10 text-sm font-medium transition-all duration-200">Hem</a>
                    <a href="/kategori/flyg" class="text-white/70 hover:text-white px-3 py-2 rounded-lg hover:bg-white/10 text-sm font-medium transition-all duration-200">Flyg</a>
                    <a href="/kategori/hotell" class="text-white/70 hover:text-white px-3 py-2 rounded-lg hover:bg-white/10 text-sm font-medium transition-all duration-200">Hotell</a>
                    <a href="/kategori/hyrbil" class="text-white/70 hover:text-white px-3 py-2 rounded-lg hover:bg-white/10 text-sm font-medium transition-all duration-200">Hyrbil</a>
                    <a href="/guider" class="text-white/70 hover:text-white px-3 py-2 rounded-lg hover:bg-white/10 text-sm font-medium transition-all duration-200">Guider</a>
                    <a href="/kategori/flyg" class="ml-2 bg-accent hover:bg-accent-hover text-white px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 shadow-sm shadow-accent/20 hover:shadow-md hover:shadow-accent/30 hover:-translate-y-0.5">
                        Alla kategorier
                    </a>
                </div>

                <!-- Mobile Hamburger (CSS-only) -->
                <details class="md:hidden relative">
                    <summary class="list-none cursor-pointer p-2 rounded-lg hover:bg-white/10 transition-colors">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </summary>
                    <div class="absolute right-0 mt-2 w-56 glass rounded-2xl shadow-xl py-2 z-50">
                        <a href="/" class="block px-4 py-3 text-gray-700 hover:bg-sand hover:text-brand rounded-lg mx-2 transition-all duration-200">Hem</a>
                        <hr class="my-2 border-gray-100 mx-4" />
                        <a href="/kategori/flyg" class="block px-4 py-3 text-gray-700 hover:bg-sand hover:text-brand rounded-lg mx-2 transition-all duration-200">Flyg</a>
                        <a href="/kategori/hotell" class="block px-4 py-3 text-gray-700 hover:bg-sand hover:text-brand rounded-lg mx-2 transition-all duration-200">Hotell</a>
                        <a href="/kategori/hyrbil" class="block px-4 py-3 text-gray-700 hover:bg-sand hover:text-brand rounded-lg mx-2 transition-all duration-200">Hyrbil</a>
                        <a href="/kategori/reseforsakring" class="block px-4 py-3 text-gray-700 hover:bg-sand hover:text-brand rounded-lg mx-2 transition-all duration-200">Reseförsäkring</a>
                        <a href="/kategori/paketresor" class="block px-4 py-3 text-gray-700 hover:bg-sand hover:text-brand rounded-lg mx-2 transition-all duration-200">Paketresor</a>
                        <a href="/kategori/aktiviteter" class="block px-4 py-3 text-gray-700 hover:bg-sand hover:text-brand rounded-lg mx-2 transition-all duration-200">Aktiviteter</a>
                        <hr class="my-2 border-gray-100 mx-4" />
                        <a href="/guider" class="block px-4 py-3 text-accent font-medium hover:bg-sand rounded-lg mx-2 transition-all duration-200">Guider</a>
                    </div>
                </details>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
        @Body
    </main>

    <!-- Footer -->
    <footer class="bg-navy-deep text-gray-300 relative overflow-hidden">
        <!-- CTA Section with gradient + noise -->
        <div class="relative bg-gradient-to-r from-brand via-brand-light to-brand overflow-hidden noise">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(245,158,11,0.1),transparent_50%)]"></div>
            <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
                <h2 class="font-display text-2xl md:text-3xl text-white mb-3">Hitta rätt resetjänst</h2>
                <p class="text-white/60 mb-6 max-w-lg mx-auto">Jämför de bästa tjänsterna för flyg, hotell, hyrbil och mer — helt oberoende.</p>
                <a href="/kategori/flyg" class="inline-flex items-center gap-2 bg-gradient-to-r from-accent to-amber-500 hover:from-accent-hover hover:to-amber-600 text-white font-semibold px-7 py-3.5 rounded-xl transition-all duration-300 shadow-lg shadow-accent/20 hover:shadow-xl hover:shadow-accent/30 hover:-translate-y-0.5 group">
                    <svg class="w-5 h-5 group-hover:rotate-12 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    Utforska tjänster
                </a>
            </div>
        </div>

        <!-- Decorative gradient orb -->
        <div class="absolute bottom-0 left-1/3 w-96 h-96 bg-accent/3 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                <!-- About -->
                <div>
                    <h3 class="font-display text-white text-lg mb-4">flygio<span class="text-accent">.se</span></h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Sveriges oberoende jämförelsesajt för resetjänster. Vi hjälper dig hitta de bästa tjänsterna för flyg, hotell, hyrbil och mer.
                    </p>
                </div>

                <!-- Categories -->
                <div>
                    <h3 class="font-display text-white text-lg mb-4">Kategorier</h3>
                    <ul class="space-y-2.5 text-sm">
                        <li><a href="/kategori/flyg" class="text-gray-400 hover:text-accent transition-colors duration-200">Flyg</a></li>
                        <li><a href="/kategori/hotell" class="text-gray-400 hover:text-accent transition-colors duration-200">Hotell</a></li>
                        <li><a href="/kategori/hyrbil" class="text-gray-400 hover:text-accent transition-colors duration-200">Hyrbil</a></li>
                        <li><a href="/kategori/reseforsakring" class="text-gray-400 hover:text-accent transition-colors duration-200">Reseförsäkring</a></li>
                        <li><a href="/kategori/paketresor" class="text-gray-400 hover:text-accent transition-colors duration-200">Paketresor</a></li>
                        <li><a href="/kategori/aktiviteter" class="text-gray-400 hover:text-accent transition-colors duration-200">Aktiviteter</a></li>
                    </ul>
                </div>

                <!-- Links -->
                <div>
                    <h3 class="font-display text-white text-lg mb-4">Snabblänkar</h3>
                    <ul class="space-y-2.5 text-sm">
                        <li><a href="/guider" class="text-gray-400 hover:text-accent transition-colors duration-200">Reseguider</a></li>
                        <li><a href="/kategori/flyg" class="text-gray-400 hover:text-accent transition-colors duration-200">Jämför flyg</a></li>
                        <li><a href="/kategori/hotell" class="text-gray-400 hover:text-accent transition-colors duration-200">Jämför hotell</a></li>
                    </ul>
                </div>
            </div>

            <hr class="my-10 border-white/5" />

            <!-- Affiliate Disclaimer -->
            <div class="text-xs text-gray-500/80 space-y-2">
                <p class="leading-relaxed">
                    Flygio.se innehåller affiliate-länkar. När du besöker en tjänst via våra länkar kan vi få en provision utan extra kostnad för dig.
                    Detta hjälper oss att driva och förbättra sajten. Vi strävar efter att ge oberoende och ärliga recensioner av alla tjänster vi listar.
                </p>
                <p>&copy; @DateTime.Now.Year flygio.se. Alla rättigheter förbehållna.</p>
            </div>
        </div>
    </footer>
</div>
