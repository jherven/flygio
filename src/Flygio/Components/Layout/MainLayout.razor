@inherits LayoutComponentBase

<div class="min-h-screen flex flex-col bg-gradient-to-br from-sky-50 to-blue-100">
    <!-- Sticky Header -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur shadow-sm">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <a href="/" class="flex items-center gap-2 text-xl font-bold text-sky-900 hover:text-sky-700 transition-colors">
                    <svg class="w-8 h-8 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                    flygio<span class="text-sky-500">.se</span>
                </a>

                <!-- Desktop Nav -->
                <div class="hidden md:flex items-center gap-6">
                    <a href="/" class="text-gray-700 hover:text-sky-600 font-medium transition-colors">Hem</a>
                    <a href="/sok" class="text-gray-700 hover:text-sky-600 font-medium transition-colors">Sök flyg</a>
                    <a href="/rutter" class="text-gray-700 hover:text-sky-600 font-medium transition-colors">Rutter</a>
                    <a href="/guider" class="text-gray-700 hover:text-sky-600 font-medium transition-colors">Guider</a>
                    <a href="/bevakning" class="bg-sky-500 hover:bg-sky-600 text-white px-4 py-2 rounded-lg font-medium transition-colors">
                        Prisbevakning
                    </a>
                </div>

                <!-- Mobile Hamburger (CSS-only) -->
                <details class="md:hidden relative">
                    <summary class="list-none cursor-pointer p-2 rounded-lg hover:bg-gray-100 transition-colors">
                        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </summary>
                    <div class="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-gray-100 py-2 z-50">
                        <a href="/" class="block px-4 py-3 text-gray-700 hover:bg-sky-50 hover:text-sky-600 transition-colors">Hem</a>
                        <a href="/sok" class="block px-4 py-3 text-gray-700 hover:bg-sky-50 hover:text-sky-600 transition-colors">Sök flyg</a>
                        <a href="/rutter" class="block px-4 py-3 text-gray-700 hover:bg-sky-50 hover:text-sky-600 transition-colors">Rutter</a>
                        <a href="/guider" class="block px-4 py-3 text-gray-700 hover:bg-sky-50 hover:text-sky-600 transition-colors">Guider</a>
                        <hr class="my-1 border-gray-100" />
                        <a href="/bevakning" class="block px-4 py-3 text-sky-600 font-medium hover:bg-sky-50 transition-colors">Prisbevakning</a>
                    </div>
                </details>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
        @Body
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- About -->
                <div>
                    <h3 class="text-white font-bold text-lg mb-3">flygio.se</h3>
                    <p class="text-sm text-gray-400">
                        Sveriges smartaste flygpris-tracker. Hitta billiga flygbiljetter, bevaka priser och få notiser vid prisfall.
                    </p>
                </div>

                <!-- Links -->
                <div>
                    <h3 class="text-white font-bold text-lg mb-3">Snabblänkar</h3>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/sok" class="hover:text-white transition-colors">Sök flyg</a></li>
                        <li><a href="/rutter" class="hover:text-white transition-colors">Populära rutter</a></li>
                        <li><a href="/guider" class="hover:text-white transition-colors">Reseguider</a></li>
                        <li><a href="/bevakning" class="hover:text-white transition-colors">Prisbevakning</a></li>
                    </ul>
                </div>

                <!-- Popular -->
                <div>
                    <h3 class="text-white font-bold text-lg mb-3">Populära rutter</h3>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/flyg/ARN-BCN" class="hover:text-white transition-colors">Stockholm → Barcelona</a></li>
                        <li><a href="/flyg/ARN-BKK" class="hover:text-white transition-colors">Stockholm → Bangkok</a></li>
                        <li><a href="/flyg/ARN-LHR" class="hover:text-white transition-colors">Stockholm → London</a></li>
                        <li><a href="/flyg/ARN-AGP" class="hover:text-white transition-colors">Stockholm → Malaga</a></li>
                    </ul>
                </div>
            </div>

            <hr class="my-8 border-gray-700" />

            <!-- Affiliate Disclaimer -->
            <div class="text-xs text-gray-500 space-y-2">
                <p>
                    Flygio.se innehåller affiliate-länkar. När du bokar flyg via våra länkar kan vi få en provision utan extra kostnad för dig.
                    Detta hjälper oss att driva och förbättra tjänsten. Priserna du ser är hämtade från Travelpayouts och kan skilja sig från det slutgiltiga priset hos flygbolaget.
                </p>
                <p>&copy; @DateTime.Now.Year flygio.se. Alla rättigheter förbehållna.</p>
            </div>
        </div>
    </footer>
</div>
