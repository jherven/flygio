---
import { getCategories } from '@/utils/data-helpers';
const categories = getCategories();
const currentPath = Astro.url.pathname;
---

<header class="bg-brand text-white">
  <div class="bg-brand/90 text-sm text-center py-1.5 px-4 text-white/80">
    Vi kan få ersättning via länkarna på sidan. Det påverkar inte våra omdömen.
  </div>
  <nav class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-heading font-bold tracking-tight hover:text-accent transition-colors">
      Flygio<span class="text-accent">.se</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-6 text-sm font-medium">
      {categories.slice(0, 4).map((cat) => (
        <li>
          <a
            href={`/${cat.slug}/`}
            class:list={[
              'hover:text-accent transition-colors',
              currentPath.startsWith(`/${cat.slug}`) ? 'text-accent' : 'text-white/90',
            ]}
          >
            {cat.name}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/guider/"
          class:list={[
            'hover:text-accent transition-colors',
            currentPath.startsWith('/guider') ? 'text-accent' : 'text-white/90',
          ]}
        >
          Guider
        </a>
      </li>
    </ul>

    <!-- Mobile nav -->
    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer p-2 -mr-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </summary>
      <ul class="absolute right-0 top-full mt-2 bg-brand border border-white/10 rounded-lg shadow-xl py-2 min-w-48 z-50">
        {categories.map((cat) => (
          <li>
            <a
              href={`/${cat.slug}/`}
              class:list={[
                'block px-4 py-2 text-sm hover:bg-white/10 transition-colors',
                currentPath.startsWith(`/${cat.slug}`) ? 'text-accent' : 'text-white/90',
              ]}
            >
              {cat.name}
            </a>
          </li>
        ))}
        <li class="border-t border-white/10 mt-1 pt-1">
          <a
            href="/guider/"
            class:list={[
              'block px-4 py-2 text-sm hover:bg-white/10 transition-colors',
              currentPath.startsWith('/guider') ? 'text-accent' : 'text-white/90',
            ]}
          >
            Guider
          </a>
        </li>
        <li>
          <a href="/om-oss/" class="block px-4 py-2 text-sm text-white/90 hover:bg-white/10 transition-colors">
            Om oss
          </a>
        </li>
      </ul>
    </details>
  </nav>
</header>
